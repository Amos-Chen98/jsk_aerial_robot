<?xml version="1.0"?>
<launch>
    <arg name="robot_ns" default="dragon" />

    <group ns="$(arg robot_ns)">
        <node pkg="dragon" type="copilot_planner" name="copilot_planner" output="screen">
            <!-- Control parameters -->
            <param name="control_loop_rate" value="50.0" />
            
            <!-- Trajectory tracking parameters -->
            <param name="trajectory_sample_interval" value="0.05" />
            <param name="trajectory_buffer_max_length" value="10.0" />
            
            <!-- Snake mode parameters -->
            <param name="snake_mode_enabled" value="true" />
            <param name="snake_ik_gain" value="0.5" />
        </node>
    </group>

</launch>
